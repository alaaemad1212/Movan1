{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "A lead registration from the landing page",
      "type": "object",
      "properties": {
        "fullName": {
          "type": "string",
          "description": "Full name of the registrant"
        },
        "phone": {
          "type": "string",
          "description": "Phone number or WhatsApp"
        },
        "city": {
          "type": "string",
          "description": "City in Saudi Arabia"
        },
        "interestType": {
          "type": "string",
          "enum": [
            "متدربة / لاعبة",
            "مدربة رياضية",
            "أخصائية تغذية",
            "أخصائية لياقة بدنية",
            "شريك أو راعي",
            "أخرى"
          ],
          "description": "Type of interest/role"
        },
        "notes": {
          "type": "string",
          "description": "Additional notes"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of registration"
        }
      },
      "required": ["fullName", "phone", "city", "interestType", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A team member or admin",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User email address"
        },
        "name": {
          "type": "string",
          "description": "User display name"
        },
        "role": {
          "type": "string",
          "enum": ["founder", "admin", "pending"],
          "description": "User role in the system"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "DueDiligenceItem": {
      "title": "Due Diligence Item",
      "description": "A question and answer item for due diligence",
      "type": "object",
      "properties": {
        "question": {
          "type": "string",
          "description": "The question being asked"
        },
        "answer": {
          "type": "string",
          "description": "The answer to the question"
        },
        "category": {
          "type": "string",
          "description": "Category of the question"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "final"],
          "description": "Status of the answer"
        },
        "sources": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Sources for the answer"
        },
        "expertNotes": {
          "type": "string",
          "description": "Notes from experts"
        },
        "authorId": {
          "type": "string",
          "description": "UID of the author"
        },
        "authorName": {
          "type": "string",
          "description": "Name of the author"
        },
        "comments": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "authorId": { "type": "string" },
              "authorName": { "type": "string" },
              "createdAt": { "type": "string" }
            }
          },
          "description": "Comments on the item"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last update"
        }
      },
      "required": ["question", "answer", "category", "status", "authorId", "authorName", "comments", "createdAt"]
    }
  },
  "firestore": {
    "registrations/{registrationId}": {
      "schema": {
        "$ref": "#/entities/Registration"
      },
      "description": "Registrations submitted from the landing page"
    },
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Team members and admins"
    },
    "due_diligence/{itemId}": {
      "schema": {
        "$ref": "#/entities/DueDiligenceItem"
      },
      "description": "Smart Due Diligence questions and answers"
    }
  }
}
